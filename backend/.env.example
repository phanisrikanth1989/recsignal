# RecSignal Backend Configuration

# App
APP_NAME=RecSignal
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:5173

# Database (SQLite default — change to oracle+oracledb:// or postgresql:// as needed)
DATABASE_URL=sqlite:///./recsignal.db

# SMTP Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=recsignal@example.com
SMTP_USE_TLS=true

# Security
AGENT_API_KEY=sample-secret-key

# Monitoring
STALE_THRESHOLD_MINUTES=20
